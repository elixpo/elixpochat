{
  "name": "elixpo-chat",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "preview": "npx @opennextjs/cloudflare build && npx wrangler dev",
    "deploy": "npx @opennextjs/cloudflare build && npx wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply elixpochat --local",
    "db:migrate:prod": "wrangler d1 migrations apply elixpochat --remote",
    "pipeline:news": "node src/lib/pipeline/news/index.js",
    "pipeline:podcast": "node src/lib/pipeline/podcast/index.js"
  },
  "dependencies": {
    "next": "^15.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "cloudinary": "^2.6.0",
    "dotenv": "^16.4.0",
    "marked": "^15.0.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.0.0",
    "@cloudflare/workers-types": "^4.20250327.0",
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "tailwindcss": "^4.1.0",
    "@tailwindcss/postcss": "^4.1.0",
    "wrangler": "^4.14.0"
  }
}
